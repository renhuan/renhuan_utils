<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="EditTextWithClear">
        <attr name="et_drawable" format="reference" />
        <attr name="et_drawableWidth" format="dimension" />
        <attr name="et_drawableHeight" format="dimension" />
        <attr name="et_drawableColor" format="color" />
    </declare-styleable>

    <declare-styleable name="StrokeTextView">
        <attr name="st_color" format="color" />
        <attr name="st_width" format="dimension" />
    </declare-styleable>


    <declare-styleable name="ShadowViewGroup">
        <attr name="containerShadowColor" format="color"/>
        <attr name="containerShadowRadius" format="dimension"/>
        <attr name="containerDeltaLength" format="dimension"/>
        <attr name="containerCornerRadius" format="dimension"/>
        <attr name="deltaX" format="dimension"/>
        <attr name="deltaY" format="dimension"/>
        <attr name="enable" format="boolean"/>
    </declare-styleable>

</resources>